# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Azure Entra ID (OAuth) ────────────────────────────────────────
# Found in: Azure Portal → App registrations → your app
VITE_AZURE_TENANT_ID=<your-tenant-id>
VITE_AZURE_CLIENT_ID=<your-client-id>
# Must match a Redirect URI registered in Azure → Authentication
VITE_AZURE_REDIRECT_URI=http://localhost:5173/auth/callback

# ── Edge Function environment (set in Supabase → Edge Functions → Secrets) ──
# SITE_URL — locks CORS and CSRF origin checking in production
# SITE_URL=https://your-app.vercel.app
#
# SUPABASE_SERVICE_ROLE_KEY — injected automatically by Supabase; do not commit
#
# Azure sync (for azure-sync-users function)
# AZURE_TENANT_ID=<same as VITE_AZURE_TENANT_ID>
# AZURE_CLIENT_ID=<same as VITE_AZURE_CLIENT_ID>
# AZURE_CLIENT_SECRET=<client-secret from Azure app registration>
#
# Email (for send-approval-email function)
# RESEND_API_KEY=re_<your-resend-api-key>
# FROM_EMAIL=noreply@seacom.com
